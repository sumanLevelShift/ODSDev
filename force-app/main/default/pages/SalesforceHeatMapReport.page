<apex:page controller="heatMapReportController" title="Heat Map Recommendations Report" renderAs="PDF" showHeader="false"  sidebar="false" cache="false" applyhtmltag="false">        
    <head>
        
        <title>Heat Map Recommendation Report</title>
        <style type="text/css" media="print">
            
            * {
            margin: 0px;
            padding: 0px;
            }
            
            *,
            :before,
            :after {
            box-sizing: border-box;
            }
            
            body {
            width: 100%;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 14px;
            color: #010101
            }
            
            .header {
            width: 100%;
            position: relative;
            }
            
            .header h1 {
            font-size: 54px;
            color: #fff;
            font-weight: 400;
            line-height: 54px;
            padding: 0 30px;
            position: absolute;
            top: 50%;
            margin-top: -65px;
            z-index: 1;
            }
            
            .header strong {
            color: #FFFFFF;
            }
            
            .head-info {
            width: 100%;
            padding: 12px 30px;
            background: #FFFFFF;
            border-top: 1px solid #cdcccb;
            border-bottom: 1px solid #cdcccb;
            color: #000000;
            font-family: Arial, Helvetica, sans-serif;
            font-weight: 400;
            }
            
            .head-info .txt {
            padding: 2px 8px;
            display:inline-block;
            }
            
            .head-info .txt:first-child {
            border-right: 1px solid #cdcccb;
            padding-left: 0px
            }
            
            .fsize20 {
            font-size: 20px;
            }
            
            .fsize18 {
            font-size: 18px;
            }
            
            .fsize16 {
            font-size: 16px;
            }
            
            .fsize13 {
            font-size: 13px;
            }
            
            .text-left {
            text-align: left;
            }
            
            .text-center {
            text-align: center;
            }
            
            .text-right {
            text-align: right;
            }
            
            .fw-light {
            font-weight: 300
            }
            
            .fw-regular {
            font-weight: 400
            }
            
            .fw-bold {
            font-weight: 700
            }
            
            .f-left {
            float: left;
            }
            
            .f-right {
            float: right;
            }
            
            .p-1 {
            padding: 10px
            }
            
            .p-2 {
            padding: 20px
            }
            
            .p-4 {
            padding: 40px
            }
            
            .pr-3 {
            padding-right: 30px;
            }
            
            .plr-3 {
            padding: 0 30px;
            }
            
            .pb-2 {
            padding-bottom: 20px;
            }
            
            .content {
            width: 100%;
            padding: 30px;
            color: #000100;
            font-weight: 300;
            line-height: 1.35;
            }
            .fsize24{
            font-size:24px;
            }
            .footer {
            width: 100%;
            color: #fff;
            position: relative;
            background: #000000;
            height: 46px;
            padding: 0 30px;
            
            }
            
            .footer p {
            position: absolute;
            right: 0px;
            margin-top: -23px;
            top: 50%;
            font-family: Arial, Helvetica, sans-serif;
            font-weight: 400;
            padding: 15px 30px;
            }
            
            .footer-logo {
            width: 89px;
            height: 65px;
            vertical-align: bottom;
            margin-right: 20px;
            margin-top:-19px;
            line-height: 0;
            }
            
            .footer-logo img {
            width: 100%;
            height: auto;
            }
            
            .header1 {
            height: 55px;            
            /*background: #50c9f3;*/
            width: 94.8%;
            color: #fff;
            padding: 0 30px;
            margin-bottom: 30px;
            background-image: url("{!URLFOR($Resource.heatMapReportImage, '/banner.png')}");
            background-position: center;
            background-size: cover;
            }
            
            .header1 span {
            font-size: 20px;
            font-weight: 600;
            padding: 14px 0;
            display: inline-block;
            }
            
            .service-logo {
            width: 65px;
            height: 65px;
            padding: 10px;
            float: left;
            vertical-align: middle;
            background: #fff;
            border: 1px solid #50c9f3;
            margin-right: 20px
            }
            
            .service-logo img {
            width: 100%;
            }
            
            .count {
            width: 80px;
            text-align: left;
            color: #fff;
            padding: 6px;
            font-weight: 700;
            display: inline-block;
            vertical-align: middle;
            float:left;
            }
            
            .red-bg {
            background: #ed1d24;
            }
            
            .orange-bg {
            background: #f79128;
            }
            
            .yellow-bg {
            background: #fdc011;
            }
            
            .light-green-bg {
            background: #8aac3e;
            }
            
            .green-bg {
            background: #258b43;
            }
            
            .blue-txt {
            color: #4fc9f4;
            margin-top: -5px;
            }
            
            .count-icon {
            width: 25px;
            text-align: center;
            display: inline-block;
            padding:4.8px 6px; 
            vertical-align: middle;
            float:left;
            }
            
            .count-icon img{
            width: 18px;
            height: 18px;
            vertical-align: middle;
            line-height:0;
            }
            .red-darkbg{
            background: #831618;
            }
            
            .orange-darkbg{
            background: #da7627;
            }
            
            .yellow-darkbg {
            background: #dfa426;
            }
            
            .light-green-darkbg {
            background: #6d8438;
            }
            
            .green-darkbg {
            background: #19783d;
            }
            
            table {
            width: 100%;
            border: none;
            color: #676767
            }
            
            table table {
            table-layout: fixed;
            margin-top: 10px
            }
            
            table table thead th {
            color: #4fc9f4;
            font-weight: 700;
            border-top: 2px solid #7c868d;
            border-bottom: 2px solid #7c868d;
            }
            
            table table tbody td {
            border-bottom: 1px solid #e6e6e5;
            vertical-align: top;
            }
            
            table table th,
            table table td {
            padding: 10px;
            }
            
            table table td strong {
            color: #000
            }
            
            table+table {
            padding: 30px 0 0 0;
            }
            
            visually-hidden {
            clip: rect(0 0 0 0);
            clip-path: inset(100%);
            height: 1px;
            overflow: hidden;
            position: absolute;
            width: 1px;
            white-space: nowrap;
            }
            
            .toc-list, .toc-list ol {
            list-style-type: none;
            }
            
            .toc-list {
            padding: 0;
            }
            
            .toc-list ol {
            padding-inline-start: 2ch;
            line-heigth:1.5;
            }
            
            .toc-list > li > a {
            font-weight: bold;
            margin-block-start: 1em;
            }
            
            .toc-list li > a {
            text-decoration: none;
            display: grid;
            grid-template-columns: auto max-content;
            align-items: end;
            }
            
            .toc-list li > a > .title {
            position: relative;
            overflow: hidden;
            }
            
            .toc-list li > a .leaders::after {
            padding-inline-start: .25ch;
            text-align: right;
            }            
            .pTitle{
            color:#4bc9f4;
            padding-bottom:10px;
            }
            .subFeaTitle{
            color:#696969;
            padding-bottom:10px;
            line-heigth:1.5;
            }
            /*print page number with table of contents*/
            .frontmatter a::after { content: leader(' ') target-counter(attr(href), page, lower-roman) }
            .bodymatter a::after { content: leader('.') target-counter(attr(href), page, lower-roman) }
            @page :first {
            margin-top: 0cm;
            padding-top: 0px;
            }
            @page{
            margin: 0px;
            padding-top: 25px;
            margin-bottom: 45px;
            size: A4 landscape;
            
            @bottom-left {
            content: element(footer);
            }
            @top-center {
            content: element(header1);
            
            }    
            margin-top: 1.5cm;
            }
            div.header1 {
            
            position: running(header1);   
            }
            div.footer {
            
            position: running(footer);   
            }
            .pagenumber:before {              
            content: counter(page);            
            } 
            .toc-list li a{
            line-heigth:1.5;
            padding:10px 0;
            }
            table tr, table td{
            page-break-inside: avoid;
            }
            td,th{
            word-wrap: break-word;
            }
            table{
            -fs-table-paginate: paginate;
            border-collapse: collapse;
            }
            li{                         
            page-break-inside:avoid;
            }
            
        </style>
    </head>
    
    <body style="width:100%">
        <div class="footer">
            <div class="footer-logo"><apex:image url="{!URLFOR($Resource.heatMapReportImage,'/footerlogo.png')}"></apex:image>
                <!-- <img src="images/footerlogo.png">--></div>
            <p class="text-right fsize13 pr-3">Heat Map Recommendations Report | <span class="pagenumber"/></p>
        </div>
        <div style="page-break-after:always;">
            <div class="header">
                <apex:image url="{!URLFOR($Resource.heatMapReportImage,'/banner.png')}" style="width:100%;max-height: 340px;object-fit: cover;object-position: top right;"/>                    
                <h1><strong>Heat Map</strong><br/> Recommendations<br/> Report</h1>
            </div>
            <div class="head-info fsize13">
                <div class="txt" >DATE: <span><apex:outputText value="{0,date, MM'/'dd'/'yyyy}">
                    <apex:param value="{!reportDate}" /> 
                    </apex:outputText></span></div>
                <div class="txt" style="border-right: 1px solid #cdcccb;padding-left: 3px">ORG NAME: <span>{!accountName}</span></div>
                <div class="txt" style="border-right: 1px solid #cdcccb;padding-left: 3px">ORG ID: <span>{!orgId}</span></div>
                <div class="txt" style="border-right: 1px solid #cdcccb;padding-left: 3px">USERNAME: <span>{!userName}</span></div>
                <div class="txt" style="padding-left: 3px">ENV: <span>{!environment}</span></div>

            </div>
            
            <div class="content" >
                <p class="fsize24 text-center p-4 " style="color:#222222;">We evaluated your Salesforce implementation and prepared this personalized
                    report to<br/>help you start planning your rollout.</p>
            </div>
        </div>
        
        <div style="page-break-after:always;">
            <div class="header1">
                <span>Table of contents</span>
            </div>
            <div class="content" style="width:95%;">
                <ol class="toc-list" role="list">
                    <li class="frontmatter">
                        <a class="pTitle fsize16" href="#Overview">
                            <span class="title">Overview<span class="leaders" aria-hidden="true"></span></span> 
                            <span data-href="Overview" class="page"><span class="visually-hidden">&nbsp;</span></span>
                        </a>
                    </li>
                    <apex:repeat value="{!productClientWrapList}" var="p">   
                        <li class="frontmatter" >
                            <a class="pTitle1" style="color:white;">
                                
                            </a>
                        </li>
                        <li class="frontmatter">
                            <a class="pTitle fsize16" href="#{!p.ProductName}">
                                <span class="title">{!p.ProductName}<span class="leaders" aria-hidden="true"></span></span> 
                                <span data-href="{!p.ProductName}" class="page"><span class="visually-hidden">&nbsp;</span></span>
                            </a>
                            <ol role="list">
                                <apex:repeat value="{!p.FeatureClientWrapList}" var="f">
                                    <li class="bodymatter">
                                        <a class="subFeaTitle" href="#{!p.ProductName} {!f.FeatureName}">
                                            <span class="title">{!f.FeatureName}<span class="leaders" aria-hidden="true"></span></span> 
                                            <span data-href="{!p.ProductName} {!f.FeatureName}" class="page"><span class="visually-hidden">&nbsp;</span></span>
                                        </a>
                                    </li>
                                </apex:repeat>
                            </ol>
                        </li>
                    </apex:repeat>
                </ol>
            </div>
        </div>
        <div style="page-break-after:always;">
            <div class="header1">
                <span>Overview</span>
            </div>
            <div class="content" style="width:95%;">
                <p id="Overview" class="fsize16" style="line-height:1.5;color:#222222;text-align: justify;">
                    DemandBlue Heat Map Recommendations Report shows the Business team of a Salesforce Org on how well they utilize their Salesforce
                    Instance to meet their business needs and provide recommendations to implement any unused product/features/sub-features to improve their
                    business. DemandBlue Heat Map Recommendation report is available at the product level, its features and sub-features levels. It shows that for a specific
                    customer, <apex:outputLabel escape="false" Value="{!overviewContent}" ></apex:outputLabel>
                </p>
                <br/>
                <p class="fsize16" style="line-height:1.5;color:#222222;text-align: justify;">
                    This view will help the customer to understand the features &amp; sub-features that they are not aware of and not used. Implementing and/or
                    improving any of these less utilized entities will only help the customer to improve their primary business goals and expand their business. For
                    example, in the Account &amp; Contact Management – one case is that when there are no new accounts &amp; contacts created recently, the utilization
                    on the Account &amp; Contact Management will be low and we understand that the Sales process needs some improvement and need to be
                    looked into, to bring in new accounts &amp; contacts.
                </p>
                <div style="text-align:center;">
                    
                    <apex:image url="{!dynamicUrl}" style="height:320px;text-align:center;"/>
                </div>
            </div>
        </div>
        <apex:variable var="cnt" value="{!0}" />    
        <apex:repeat value="{!productClientWrapList}" var="p">     
            <div style="{!if(cnt < 1, 'page-break-before:avoid;','page-break-before:always;')}">
                <apex:variable var="cnt" value="{!cnt+1}"/>
                
                <div class="header1 productLogo">
                    <div class="service-logo">
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/SalesCloud.png')}" rendered="{!CONTAINS(p.ProductName, 'Sales Cloud')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/ServiceCloud.png')}" rendered="{!CONTAINS(p.ProductName, 'Service Cloud')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/SalesforcePlatform.png')}" rendered="{!CONTAINS(p.ProductName, 'Salesforce Platform')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/MarketingCloud.png')}" rendered="{!CONTAINS(p.ProductName, 'Marketing Cloud')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/FSL.png')}" rendered="{!CONTAINS(p.ProductName, 'Field Service (FSL)')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/ExperienceCloud.png')}" rendered="{!CONTAINS(p.ProductName, 'Experience Cloud')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/Pardot.png')}" rendered="{!CONTAINS(p.ProductName, 'Pardot')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/cpq.png')}" rendered="{!CONTAINS(p.ProductName, 'Salesforce CPQ')}"/>
                        <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/SalesforceBilling.png')}" rendered="{!CONTAINS(p.ProductName, 'Salesforce Billing')}"/>
                    </div>
                    <span >{!p.ProductName}</span>
                    <span class="f-right">{!p.productClientUsage}%</span>
                </div>
                <div class="content" id="{!p.ProductName}" >
                    <p class="fsize16 fw-bold text-left pb-2 productDes" style="width:95%;text-align: justify;">{!p.ProductDescription}</p>
                    <table border="0" cellspacing="10" cellpadding="0" style="width:95%;border:none;" >
                        <apex:repeat value="{!p.FeatureClientWrapList}" var="f">
                            <tr valign="top" id="{!p.ProductName} {!f.FeatureName}" >
                                <td width="150">
                                    <div style="min-height:28px;overflow:hidden;">
                                        <p class="{!f.classNamePar}">{!f.FeatureClientUsage}%</p>
                                        <span class="{!f.classNamespan}">
                                            <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/closeicon.png')}" rendered="{!CONTAINS(f.classNamePar, 'red-bg count')}"/>
                                            <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/warnicon.png')}" rendered="{!CONTAINS(f.classNamePar, 'orange-bg count')}"/>
                                            <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/exclaimicon.png')}" rendered="{!CONTAINS(f.classNamePar, 'yellow-bg count')}"/>
                                            <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/checkicon.png')}" rendered="{!f.classNamePar=='light-green-bg count'}"/>
                                            <apex:image url="{!URLFOR($Resource.heatMapReportImage, '/successicon.png')}" rendered="{!f.classNamePar== 'green-bg count'}"/>
                                        </span>
                                    </div>
                                </td>
                                <td >
                                    <p class="blue-txt fsize16 fw-bold" >{!f.FeatureName}</p>
                                    <p style="text-align: justify;">{!f.FeatureDescription}</p>
                                    <apex:outputPanel rendered="{!(f.ProductSubfeatureClient.size !=0) }">
                                        <table cellspacing="0" cellpadding="0" >
                                            <thead>
                                                <tr >
                                                    <th align="left" style="white-space: normal;width:20%;">Sub Feature</th>
                                                    <th align="left" >Description / Recommendations</th>
                                                    <th align="center" style="white-space: normal;width:20%;">Utilization Percentage</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <apex:repeat value="{!f.ProductSubfeatureClient}" var="sf">
                                                    <tr >
                                                        <td >{!sf.SubFeatureName}</td>
                                                        <td style="text-align: justify;text-justify: inter-word;">{!sf.SubFeatureDescription}</td>
                                                        <td align="center"><p class="percent-values fw-bold" style="color:#000;"> {!sf.SubFeatureClientUsage}%</p></td>
                                                    </tr>
                                                </apex:repeat>
                                            </tbody>
                                        </table>
                                    </apex:outputPanel>
                                </td>
                            </tr>
                        </apex:repeat>
                    </table>
                </div>
            </div>
        </apex:repeat>
    </body>
</apex:page>