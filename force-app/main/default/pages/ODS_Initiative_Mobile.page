                WeekDay6 = shortMonth[SaturdayDate.getMonth()] + " " + SaturdayDate.getDate(); // AssignWeekValueToSet(StartDateOfWeek.getDate()+ 5,StartDateOfWeek,EndDateOfWeek);
                //alert(WeekDay2)
                
                $("#HdrDay1").html(WeekDay1 + "<br/> MON");
