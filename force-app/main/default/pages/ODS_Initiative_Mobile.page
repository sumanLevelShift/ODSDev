            function AssignMonthValueToSet(valToSet, dateVal) {
                var days = getDaysInMonth(dateVal.getMonth() + 1, dateVal.getFullYear());
                if (valToSet > days) {
                    return dateVal.getMonth() + 2;
                } else {
                    return dateVal.getMonth() + 1;
                }
            }
            
            function AssignWeekValueToSet(valToSet, dateVal, dateSetVal) {
                var shortMonth = new Array();
                shortMonth[0] = "JAN";
                shortMonth[1] = "FEB";
                shortMonth[2] = "MAR";
                shortMonth[3] = "APR";
                shortMonth[4] = "MAY";
                shortMonth[5] = "JUN";
                shortMonth[6] = "JUL";
                shortMonth[7] = "AUG";
                shortMonth[8] = "SEP";
                shortMonth[9] = "OCT";
                shortMonth[10] = "NOV";
                shortMonth[11] = "DEC";
                
                var days = getDaysInMonth(dateVal.getMonth() + 1, dateVal.getFullYear());
                if (valToSet <= days) {
                    //return (new Date(dateVal) ).toLocaleString(locale, { month: "short" }) +" " +valToSet;
                    return shortMonth[dateVal.getMonth()] + " " + valToSet;
                } else {
                    //return (new Date(dateSetVal)).toLocaleString(locale, { month: "short" }) +" " +(valToSet - days);
                    return shortMonth[dateSetVal.getMonth()] + " " + (valToSet - days);
                }
            }
            
            
            
            var getDaysInMonth = function(month, year) {
                return new Date(year, month, 0).getDate();
            }
            
            function FormatDate(datevalue) {
                var dd = datevalue.getDate();
                var mm = datevalue.getMonth() + 1;
                var y = datevalue.getFullYear();
                var FormattedDate = mm + "/" + dd + "/" + y;
                return FormattedDate;
            }
            
            function ValidateInitiativeRows(status){
                var initiativename =  $('#initiative_name').val().trim();
                var jiraId = $('#jiraId').val().trim();
                if(initiativename.length < 2){
                    alert("Initiative Name is mandatory");
                    return false;
                }
                if(jiraId.length == 0){
                    alert("JIRA Id is mandatory");
                    return false;
                }
                
                
                <!-- DCO-155 on 28/09/2022-->
                if(status == 'Submitted' || status == 'btnSavePostSubmit'){
                
                        var Total_hrs = parseFloat($('#tdColTotal').html());
                        var businessChallange = $("#BusinessChallenge").val().trim();
                        var personasInvolved = $("#PersonasInvolved").val().trim();
                        var technologyDetails = $("#TechnologyDetails").val().trim();
                        var outcomeOfOurSolution = $("#OutcomeOfOurSolution").val().trim();
                        
                        if(Total_hrs >= {!$Label.Estimated_Hr_Threshold}){
                            
                            if(businessChallange.length<{!$Label.Content_Entry}){
                                alert('Business Challenge should not be empty and must be greater than ' + {!$Label.Content_Entry} + ' characters!!');
                                return false;
                            }
                            else if(personasInvolved.length<{!$Label.Content_Entry}){
                                alert('Personas Involved should not be empty and must be greater than ' + {!$Label.Content_Entry} + ' characters!!');
                                return false;
                            }
                            else if(technologyDetails.length<{!$Label.Content_Entry}){
                                alert('Technology Details should not be empty and must be greater than ' + {!$Label.Content_Entry} + ' characters!!');
                                return false;
                            }
                            else if(outcomeOfOurSolution.length<{!$Label.Content_Entry}){
                                alert('Outcome Of Our Solution should not be empty and must be greater than ' + {!$Label.Content_Entry} + ' characters!!');
                                return false;
                            }
                               
                        }
                }
                
                
                
                //added by Indhu on 28/08/2019
                // Initative name field validation
                if(initiativename.length > 80){
                    alert("Initiative Name should not be greater than 80 character");
                    return false;
                }
                var firstValue = $('#date_service').val().split('/');
                var secondValue = $('#date_service1').val().split('/');
                var thirdValue = $('#date_service2').val().split('/');
                
                var StartDate = $('#date_service').val();
                var EndDate = $('#date_service1').val();
                var UATExpectedDate = $('#date_service2').val();
                
                if(StartDate.length == 0){
                    alert('Probable Start Date should not be empty');
                    return false;
                }
                
                if(EndDate.length == 0){
                    alert('Probable End Date should not be empty');
                    return false;
                }
                
                var probableStart = new Date(StartDate);
                var probableEnd = new Date(EndDate);
                
                if(probableStart > probableEnd){ 
                    alert('Probable End date should be more than Probable Start date');
                    return false;
                }
                if(UATExpectedDate != '' && (PortalUserRole == 'Technical Account Manager' || PortalUserRole == 'Practice Head')){
                    var UATExpected = new Date(UATExpectedDate);
                    if(UATExpected < probableStart){ 
                        alert('UAT Expected Date should be later than Probable Start date.');
                        return false;
                    }
                }
                
                var initiativeType = $('.initiativeType').val();
                var programmingReason = $('.programmingReason').val().trim();
                if(initiativeType == 'None'){
                    alert('Initiative Type is Mandatory');
                    return false;
                }
                if(initiativeType == 'Programming' && programmingReason == ''){
                    alert('Specify the reason the Initiative can’t be done in a declarative way');
                    return false;
                }                     
                var initiativeTrig = $('.initiativeTrig').val();
                var initiativeTag = $('.initiativeTag').val();
                if(initiativeTrig == 'None'){
                    alert('Trigger for Initiative is Mandatory');
                    return false;
                }
                if(initiativeTag == null){
                    alert('Tags about Initiative is Mandatory');
                    return false;
                }
                
                var total_Count = parseFloat($('#tdColTotal').html());
                
                if(status != 'Saved'){
                    if(total_Count == 0){
                        alert('Estimates Should not be Empty');
                        return false;
                    }
                }
                if(status == 'Submitted'){
                    var OffshoreEstimate = $('#OffshoreEstimate').val();
                    
                    if(OffshoreEstimate == 0){
                        alert('Offshore estimate field should have the estimated provided by the delivery team.');
                        return false;
                    }
                }
                //Added by Harish for TPM  - submit button validation
                    
                    if(status == 'Submitted'){
                         var technicalProjectManager = $('.technicalProjectManager').val();
    
                         if(technicalProjectManager =='None'){
                            alert('Please assign a Technical Project Manager to this initiative.');
                            return false;
                         }
                      }
                
                return true;
            }
            
