            <script>
            var utilizationHurs=0.0; 
            var consumedHrs = 0.0;
            var unUtilizedHrs=0.0;
            var remainingHrs=0.0;
            window.onload=function(){
                hrs();
                toHide();
                //debugger;
                var approvalType = getParameterByName('Type');
                if(approvalType == 'Reject'){
                    $('#btnReject').click();
                    
                }
            }
            
            
            function getParameterByName(name, url) {
                if (!url) url = window.location.href;
                name = name.replace(/[\[\]]/g, '\\$&');
                var regex = new RegExp('[?&]' + name + '(=([^&#]*)|&|#|$)'),
                    results = regex.exec(url);
                if (!results) return null;
                if (!results[2]) return '';
                return decodeURIComponent(results[2].replace(/\+/g, ' '));
            }
            </script>   
            
            
            <script>    
            function hrs(){
                var crntInvId =  '{!$CurrentPage.parameters.CurrenInitiativeId}';
                // debugger;
                Visualforce.remoting.Manager.invokeAction(
                    '{!$RemoteAction.ODS_InitiativeControllerMobile.GetUtilizedHours}', 
                    crntInvId,
                    function(result, event){
                        // debugger;
                        if(result === null)
                        {
                            utilizationHurs = 0.0;
                            consumedHrs = 0.0;
                            unUtilizedHrs=0.0;
                            remainingHrs=0.0;
                        }
                        else
                        {                   
                            var hrsArray = result.split("|");                                     
                            utilizationHurs = hrsArray[0];
                            consumedHrs = hrsArray[1];
                            unUtilizedHrs=hrsArray[2];
                            remainingHrs=hrsArray[3];
                        }
                    });
                
            }
            
            var chart = AmCharts.makeChart("chartdiv", {
                "theme": "light",
                "type": "gauge",
                "axes": [{
                    "topTextFontSize":16,
                    "topTextYOffset":30,
                    "topTextColor": "#FFFFFF",
                    "axisColor": "#FF0000",
                    "axisThickness": 0,
                    "centerY": "18%",
                    "endValue": 100,
                    "color": "#FFFFFF",
                    "gridInside": true,
                    "labelFrequency": 10,
                    "inside": false,
                    "radius": "95%",
                    "valueInterval": 10,
                    "minorTickLength": 0,
                    "tickColor": "#FFFFFF",
                    "tickThickness": 2,
                    "startAngle": -90,
                    "endAngle": 90,
                    "unit": "%",
                    "bandOutlineAlpha": 0,
                    "bands": [{
                        "color": "#FFFFFF ",
                        "endValue": 100,
                        "innerRadius": "132%",
                        "radius": "135%",
                        "gradientRatio": [0, 0, 0],
                        "startValue": 0
                    }]
                }],
                "arrows": [{
                    "color": "#FFFFFF",
                    "alpha": 1,
                    "innerRadius": "0",
                    "nailRadius": 10,
                    "startWidth": 8,
                    "radius": "130%"
                }]
            });
            
            setInterval(randomValue, 50);
            
            // set random value
            function randomValue() {
                var value = utilizationHurs;
                var consumedValue = consumedHrs;
                chart.arrows[0].setValue(value);
                
                chart.axes[0].setTopText(consumedValue + " Hours");
                // adjust darker band to new value
                if(typeof chart.axes[0].bands[1] !== 'undefined'){
                chart.axes[0].bands[1].setEndValue(value);
            }
            }
            var chartnew = AmCharts.makeChart("chartdivnew", {
                "theme": "light",
                "type": "gauge",
                "axes": [{
                    "topTextFontSize":16,
                    "topTextYOffset":30,
                    "topTextColor": "#FFFFFF",
                    "axisColor": "#FF0000",
                    "axisThickness": 0,
                    "centerY": "18%",
                    "endValue": 100,
                    "color": "#FFFFFF",
                    "gridInside": true,
                    "labelFrequency": 10,
                    "inside": false,
                    "radius": "95%",
                    "valueInterval": 10,
                    "minorTickLength": 0,
                    "tickColor": "#FFFFFF",
                    "tickThickness": 2,
                    "startAngle": -90,
                    "endAngle": 90,
                    "unit": "%",
                    "bandOutlineAlpha": 0,
                    "bands": [{
                        "color": "#FFFFFF ",
                        "endValue": 100,
                        "innerRadius": "132%",
                        "radius": "135%",
                        "gradientRatio": [0, 0, 0],
                        "startValue": 0
                    }]
                }],
                "arrows": [{
                    "color": "#FFFFFF",
                    "alpha": 1,
                    "innerRadius": "0",
                    "nailRadius": 10,
                    "startWidth": 8,
                    "radius": "130%"
                }]
            });
            
            setInterval(randomValueNew, 50);
            
            // set random value
            function randomValueNew() {
                var value = unUtilizedHrs;
                var remainingValue = remainingHrs;
                chartnew.arrows[0].setValue(value);
                
                chartnew.axes[0].setTopText(remainingValue + " Hours");
                // adjust darker band to new value
                if(typeof chartnew.axes[0].bands[1] !== 'undefined'){
                chartnew.axes[0].bands[1].setEndValue(value);
            }
            }
            function toHide(){
                var status =  '{!$CurrentPage.parameters.Status}'; 
                if(status == '' ||status == 'Re-evaluate' || status == 'New' || status == 'Initiative Submitted' || status == 'Saved'  ){
                    $('#chartdiv').hide();
                    $('#chartdivnew').hide();
                    $('#chartdiv2').hide(); 
                    
                }
            }
            </script>
            
            
