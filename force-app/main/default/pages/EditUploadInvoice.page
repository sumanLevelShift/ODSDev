        function isNumber(evt) {
            evt = (evt) ? evt : window.event;
            var charCode = (evt.which) ? evt.which : evt.keyCode;
            if (!(charCode > 31 && (charCode < 48 || charCode > 57) && charCode ==91 )) {
                return false;
            }
            return true;
        }
        function BlockSpecialCharacter(key){
            var keycode = (key.which) ? key.which : key.keyCode;
            if ((keycode >= 65 && keycode <= 90) || (keycode >= 97 && keycode <= 122) || (keycode >= 46 && keycode <= 57) || keycode == 32 || keycode == 95 || keycode == 13)
                return true;
            else
                return false;
        }
        function downloadAttachment(attachmentId, type)
        {
            debugger;
            // alert('download Attachment id1 '+attachmentId);
            if(type == 'Invoice' || type == 'Timesheet' || type == 'Supporting Document')
            {
                var base_url = window.location.origin;
                // 	alert('download Attachment id3 '+attachmentId);  
                var win = window.open(base_url +'/sfc/servlet.shepherd/version/download/'+attachmentId, '_blank');	                
                // 	alert('download Attachment id2 '+attachmentId);
                if (!window.loction.origin){
                    
                    base_url  = window.location.protocol + "//" + window.location.hostname + (window.location.port ? ':' + window.location.port: '');
                } 
                win.focus();
            }
            else if(type == '')
            {
                //  alert('download Attachment id4 '+attachmentId);
                var base_url = window.location.origin;
                if (!window.location.origin) {
                    
                    base_url  = window.location.protocol + "//" + window.location.hostname + (window.location.port ? ':' + window.location.port: '');
                }
                
                var win = window.open(base_url +'/servlet/servlet.FileDownload?file='+attachmentId, '_blank');
                win.focus();
            }
            
        }
        var errorMessage = '';
        var isValidFileType = true;
        var isValidInvoice = true;
        
        
        
        function uploadAttachment(type)
        {
            
            var id ='{!Invoice.Invoice_ID__c}';
            var returnValue;
            var uploadFile;
            //  alert('InvoiceId '+id);
            if(id != '')
            {
                //  alert('InvoiceType '+type);
                $('[id$=documentType]').val(type);
                uploadFile = $('[id$=uploadFile]').val();
                if ($.trim(uploadFile) =="") {
                    alert("Please select a file");
                    return false;
                }
                else {
                    $('[id$=uploadFile]').addClass("");
                    $("#divErrorMessageFileType").text("");
                    
                }
                if(uploadFile != '')
                {
                    $("#divErrorMessageFileType").text("");
                    if(type == 'Invoice'){
                        var validFiles = '{!$Label.ODS_InvoiceExtenstion}'; //if above this
                        var splitFileExtensions = validFiles.split(',');
                        // alert(splitFileExtensions);
                        var fileExtension = uploadFile.substr(uploadFile.lastIndexOf('.') + 1);
                        for(var i = 0; i < splitFileExtensions.length; i++) {
                            
                            if(fileExtension == splitFileExtensions[i])
                            {
                                isValidFileType = true;
                                
                                break;
                            }
                            else
                            {
                                isValidFileType = false;
                            }
                        }
                    }
                    
                    //write supporting document code here.
                    if(type == 'Supporting Document'){
                        var validFiles = '{!$Label.ODS_InvoiceSupportingTypeExtenstion}'; //if above this
                        var splitFileExtensions = validFiles.split(',');
                        // alert(splitFileExtensions);
                        var fileExtension = uploadFile.substr(uploadFile.lastIndexOf('.') + 1);
                        for(var i = 0; i < splitFileExtensions.length; i++) {
                            
                            if(fileExtension == splitFileExtensions[i])
                            {
                                isValidFileType = true;
                                break;
                            }
                            else
                            {
                                isValidFileType = false;
                            }
                        }
                    }
                    
                    debugger;
                    if(isValidFileType ==false)
                    {
                        isValidInvoice = false;                          
                        $("#divErrorMessageFileType").text("Invalid File Type!");
                        return false;
                    } else{
                        var input=document.getElementById('uploadFile').files;
                        var reader = new FileReader();
                        reader.readAsDataURL(input[0]);
                        reader.onload = function(e) 
                        {
                            var fileString = e.target.result;
                            var attachmentbodybase64 = window.btoa(fileString)
                            console.log(fileString)
                            debugger;
                            sendAttachmentToController(input[0].name,fileString);
                            
                            
                        }
                    }
                }
            }
            else
            {
                returnValue = false;
            }
            return returnValue;
        }
        
        function ValidateInvoiceDetails(status)
        {
            
            var returnValue = false;
            
            // debugger;
           
            console.log('Heya m in Validation!!');
            
            errorMessage ='';  
            var id ='{!Invoice.Invoice_ID__c}';
            var Month = $('[id$=uploadInvoiceMonth]').val();
            var Year = $('[id$=uploadInvoiceYear]').val();
            var InvoiceId = document.getElementById('{!$Component.formId.InvoiceId}').value;
            var billingStart = $('.tfrom_date').val();
            var billingEnd = $('.tto_date').val();
            var cmmnt = $('[id$=uploadInvoiceComments]').val();
            var dateObj = new Date();
            var currentMonth = dateObj.getUTCMonth() + 1; //months from 1-12
            var currentYear = dateObj.getUTCFullYear(); 
            var startDate = new Date(billingStart);
            var endDate = new Date(billingEnd);
            var emailAddress=$('[id$=EmailAddress]').val();
            var ccEmailAddress=$('[id$=CCAddress]').val();
            if(ccEmailAddress.trim().length > 0){
            	emailAddress += ',' + ccEmailAddress;
            }
            
            var emails = emailAddress.split(',');
            
            
            var emailValid = true;
            //var regex = /^((?!\.)[\w\-_.]*[^.])(@\w+)(\.\w+(\.\w+)?[^.\W])$/;
            var regex = /^((?!\.)[\w\-_.]*[^.])(@[\w\-]+)(\.\w+(\.\w+)?[^.\W])$/;

            for (var i = 0; i < emails.length; i++) {
                if( emails[i] === "" || !regex.test(emails[i].replace(/\s/g, ""))){
                    emailValid = false;
                }
            }
            if(emailValid==false){
                alert('Please enter valid email address');
                returnValue = false;
                return false;
            }
            
            if(Month == 'Month' && Year == 'Year' ){
                alert('Please select Year & Month');
                returnValue = false;
            }
            else if(Month == 'Month')
            {
                alert('Please select Month');
                returnValue = false;
            }
                else if(Year == 'Year')
                {
                    alert('Please select Year');
                    returnValue = false;
                }
            
                    else if(billingStart.length == 0){
                        $('.tfrom_date').addClass('mandatoryClass');
                        alert("Billing start date is mandatory");
                        returnValue = false;
                    }
                        else if(billingEnd.length == 0){
                            $('.tto_date').addClass('mandatoryClass');
                            alert("Billing end date is mandatory");
                            returnValue = false;
                        }
                            else if(startDate > endDate){
                                $('.tfrom_date').addClass('mandatoryClass');
                                $('.tto_date').addClass('mandatoryClass');
                                alert("Billing end date should be more than Billing start date");
                                returnValue = false;
                            }
                                else
                                {  
                                    $('.tfrom_date').removeClass('mandatoryClass');
                                    $('.tto_date').removeClass('mandatoryClass');               
                                    debugger;
                                    if(status == 'Submitted')
                                    {
                                        
                                        Visualforce.remoting.Manager.invokeAction(
                                            '{!$RemoteAction.ODS_EditUploadInvoicecontroller.validateOnSubmitUpdated}',
                                            id,
                                            function(result, event){
                                                if (event.status) {
                                                    if((result.indexOf("TI")  > -1 )||(result.indexOf("IT")  > -1))
                                                    { 
                                                        $('[id$=DisabledInvoiceStatus]').val(status);
                                                        $('[id$=uploadDisableButton]').trigger("click");
                                                        //return true;   
                                                    }
                                                    else if((result.indexOf("T")  > -1) && (!result.indexOf("I")  > -1))
                                                    {
                                                        alert('You can not submit it, Invoice file is not present.');
                                                        return false;
                                                    }
                                                        else if((result.indexOf("I")  > -1) && (!result.indexOf("T")  > -1))
                                                        {
                                                            alert('You can not submit it, Timesheet file is not present.');
                                                            return false;
                                                        }
                                                            else
                                                            {
                                                                alert('You can not submit it, Invoice and Timesheet files are not present.');
                                                                return false;
                                                            }
                                                    debugger;
                                                } else if (event.type === 'exception') {
                                                    alert(event.message);
                                                } else {
                                                    alert(event.message);
                                                } 
                                            }, 
                                            {escape: true}
                                        );
                                    }
                                    else
                                    {
                                        $('[id$=DisabledInvoiceStatus]').val(status);
                                        returnValue = true;
                                    }             
                                }
            return returnValue;
        } 
        
        function IsInputEmpty(inputName) {
            
            var inputControl = document.getElementById(inputName).value;
            if ($.trim(inputControl) =="") {
                document.getElementById(inputName).className = "mandatoryClass";
                $("#divErrorMessageFileType").text("Please select a file");
                return true;
            }
            else {
                document.getElementById(inputName).className = "";
                $("#divErrorMessageFileType").text("");
                return false;
            }
        }
        function ValidateInvoiceMonthYear() {
            debugger;
            var Month = $('[id$=uploadInvoiceMonth]').val();
            var Year = $('[id$=uploadInvoiceYear]').val();
            
            var dateObj = new Date();
            var currentMonth = dateObj.getUTCMonth() + 1; //months from 1-12
            var currentYear = dateObj.getUTCFullYear(); 
            if(getMonthFromString(Month) > currentMonth && Year == currentYear)
            {
                alert('Sorry, you cannot select upcoming months.');
                $('[id$=uploadInvoiceMonth]').val('Month');
                return false;
            }
            return false;
        }
        
        function getMonthFromString(mon){
            return new Date(Date.parse(mon +" 1, 2012")).getMonth()+1
        }
        
