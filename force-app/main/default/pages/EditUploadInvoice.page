                                            </label> 
                                            <div class="col-md-8 col-sm-8 col-xs-12">
                                                <!-- <apex:selectList styleClass="form-control" disabled="true" value="{!Invoice.Status__c}" id="uploadInvoiceStatus" size="1">
<apex:selectoptions value="{!getInvoiceStatus}"/> 
</apex:selectList> -->
                                                <apex:input type="text" disabled="true" styleClass="form-control" value="{!InvoiceStatus}" id="uploadInvoiceStatus"/>
                                                
                                            </div> 
                                        </div>
                                        
                                        
                                        <div class="form-group">
                                            <label class="col-md-4 col-sm-4 col-xs-12 control-label" width = "10%">Comments<span style="color:#ff9797; font-size:15px; cursor:default;"></span>
                                            </label>
                                            <div class="col-md-8 col-sm-8 col-xs-12">
                                                <apex:inputTextarea styleClass="form-control" rows="3"  value="{!CommentData }" onkeypress="return BlockSpecialCharacter(event)" id="uploadInvoiceComments" html-placeholder="Comments" style="margin-bottom:20px;"/> 
                                                <!--  <apex:inputText styleClass="form-control" value="{!CommentData}" id="uploadInvoiceComments" onkeypress="return BlockSpecialCharacter(event)" html-placeholder="Comments" style="margin-bottom:20px;"/> -->
                                                <!--  <apex:input type="text" styleClass="form-control" value="{!CommentData}" id="uploadInvoiceComments" onkeypress="return BlockSpecialCharacter(event)" html-placeholder="Comments" style="margin-bottom:20px; height:150px;"/>--> 
                                            </div>
                                        </div>
                                    </div>
                                    <apex:inputField value="{!Invoice.Invoice_ID__c}" styleClass="hideClass"  id="InvoiceId" /> 
                                    <apex:inputField value="{!Invoice.Status__c}" id="DisabledInvoiceStatus" styleClass="hideClass form-control"/>
                                    <apex:input type="text"   value="{!fileType}" id="documentType" styleClass="hideClass form-control"/>
                                </div>
                            </apex:actionRegion>
                            <div class="clr"></div>
                        </div>
                    </div>
                    <div id="attachment" style="{!IF(AND(isCustomer = false,ShowUploadInvoice=true,NOT(InvoiceStatus == 'Submitted')), 'display:block', 'display:none')}" >
                        <div class="panel panel-default">   
                            <div class="panel-heading" style="color: white;background-color: #4ECAF4;">
                                <h3 style=" display:inline;" class="panel-title">UPLOAD ATTACHMENT</h3>
                                <span class="pull-right clickable" style="margin-top: 0.2px;"><i class="fa fa-chevron-up" aria-hidden="true"></i></span>
                            </div> 
                            <div class="panel-body">
                                <div style="float:left; ">
                                    <input id="uploadFile" type="file"  value="{!blobBody}" filename="{!filename}" name="files"/> 
                                    <!--<apex:inputFile value="{!blobBody}"  id="uploadFile" filename="{!filename}" title="Max file size is 5MB" /> -->
                                </div>
                                <div style="float:right;">
                                    <apex:outputPanel rendered="{!ShowUploadInvoice && PortalRole != 'Partner'}">
                                        <input class="savebutton popup-add save-submit"  type="button" value="Upload Supporting Document" id="attachAttachment" onClick="return uploadAttachment('Supporting Document');" status="statusSaveTrip"  />
                                        
                                    </apex:outputPanel>
                                    <apex:outputPanel rendered="{!(NOT(hasInvoiceFile)&& ShowUploadInvoice && PortalRole != 'Partner')}">
                                        <input class="savebutton popup-add save-submit"  type="button" value="Upload Invoice" id="InvoiceAttachment" onClick="return uploadAttachment('Invoice');" status="statusSaveTrip"  />
                                        
                                    </apex:outputPanel>
                                    
                                    <!--<apex:commandbutton styleClass="popup-add save-submit" Value="Upload Supporting Document" id="attachAttachment"  action="{!attachFile}"  onClick="return uploadAttachment('Supporting Document');" status="statusSaveTrip" rendered="{!ShowUploadInvoice && PortalRole != 'Partner'}" />
<apex:commandbutton styleClass="popup-add save-submit" Value="Upload Invoice" id="InvoiceAttachment"  action="{!attachFile}"  onClick="return uploadAttachment('Invoice');" status="statusSaveTrip" rendered="{!(NOT(hasInvoiceFile)&& ShowUploadInvoice && PortalRole != 'Partner')}" />
<!--<apex:commandbutton styleClass="popup-add save-submit" Value="UPLOAD SUPPORTING DOCUMENT" id="uploadSupportingAttachment" action="{!attachFile}"  onClick="return uploadAttachment('Supporting Document');"  status="statusSaveTrip" reRender="documentSection,attachment,pgmsg"  rendered="{!ShowUploadInvoice && PortalRole != 'Partner'}" immediate="true"  /> -->
                                    <!-- <apex:commandbutton styleClass="popup-add save-submit" Value="UPLOAD INVOICE" id="uploadInvoiceAttachment" action="{!attachFile}"  onClick="return uploadAttachment('Invoice');"  status="statusSaveTrip"  rendered="{!ShowUploadInvoice && PortalRole != 'Partner'}"/> -->
                                </div>
                                
                            </div>
                        </div>
                    </div>
                    <div id="documentSection" style="{!IF(ShowUploadInvoice=true, 'display:block', 'display:none')}" >
                        <div class="panel panel-default">   
                            <div class="panel-heading" style="color: white;background-color: #4ECAF4;">
                                <h3 style=" display:inline;" class="panel-title">DOCUMENTS</h3>
                                <span class="pull-right clickable" style="margin-top: 0.2px;"><i class="fa fa-chevron-up" aria-hidden="true"></i></span>
                            </div> 
                            <div class="panel-body">
                                <apex:pageBlock >
                                    <apex:pageBlockTable StyleClass="datatable timeline" id="pgTable" Style="cellpadding:0; cellspacing:0; width:100%;color:#4ECAF4;"  value="{!wrapAttachmentList}" var="Attachment"
                                                         rendered="{!(wrapAttachmentList.size!=0 && wrapAttachmentList !='') }">                        
                                        
                                        <apex:column headerValue="Name" value="{!Attachment.documentName}"  style="text-align:left; border-right-width: 1px;"/>
                                        <apex:column headerValue="Type" value="{!Attachment.docuemtType}"  style="text-align:left; border-right-width: 1px;"/>
                                        <apex:column headerValue="Action" style="text-align:left; border-left-width: 1px;">
                                            <apex:commandLink styleClass="time_view" title="Delete" status="statusSaveTrip"  action="{!DeleteAttachment}" rendered="{!(NOT(isCustomer) && NOT(InvoiceStatus == 'Submitted' || InvoiceStatus == 'Approved'))}">                                            
                                                <apex:param name="AttachmentToDelete" value="{!Attachment.documentId}" assignTo="{!AttachmentToDelete}"/>
                                                <apex:param name="AttachmentType" value="{!Attachment.docuemtType}" assignTo="{!AttachmentType}"/>
                                                <strong><i class="fa fa-trash" aria-hidden="true"></i></strong>
                                            </apex:commandLink>
                                            <apex:commandLink styleClass="time_view" title="Download" html-data-toggle="#" html-data-target="#myModal" onClick="downloadAttachment('{!Attachment.documentId}','{!Attachment.docuemtType}'); return false">                                            
                                                <apex:param name="AtachmentId" value="{!Attachment.documentId}"/>    
                                                <strong><i class="fa fa-download" aria-hidden="true"></i></strong>
                                            </apex:commandLink> 
                                        </apex:column>
                                    </apex:pageBlockTable>
                                </apex:pageBlock>
                                
                            </div>
                        </div>
                    </div> 
                    <div id="emailSection" style="{!IF(AND(isCustomer = false,isPartner = false), 'display:block', 'display:none')}" >
                        <div class="panel panel-default">   
                            <div class="panel-heading" style="color: white;background-color: #4ECAF4;">
                                <h3 style=" display:inline;" class="panel-title">Invoice Email</h3>
                                <span class="pull-right clickable" style="margin-top: 0.2px;"><i class="fa fa-chevron-up" aria-hidden="true"></i></span>
                            </div> 
                            <div class="panel-body">
                                <div class="col-md-6 col-sm-6 col-xs-6">
                                    <div class="form-horizontal">
                                        <div class="form-group">
                                            <label class="col-md-4 col-sm-4 col-xs-12 control-label " width = "10%">Email Address<span style="color:#ff9797; font-size:15px; cursor:default;" title="Mandatory">*</span>
                                            </label>
                                            <div class="col-md-8 col-sm-8 col-xs-12">
                                                <apex:input type="text"  styleClass="form-control" value="{!toAddress}" id="EmailAddress" html-placeholder="Email Address"/>
                                            </div>
                                        </div>  
                                    </div>
                                </div>
                                <div class="col-md-6 col-sm-6 col-xs-6">
                                    <div class="form-horizontal"> 
                                        <div class="form-group">
                                            <label class="col-md-4 col-sm-4 col-xs-12 control-label " width = "10%">CC Address<span style="color:#ff9797; font-size:15px; cursor:default;" ></span>
                                            </label>
                                            <div class="col-md-8 col-sm-8 col-xs-12">
                                                <apex:input type="text"  styleClass="form-control" value="{!ccAddress}" id="CCAddress" html-placeholder="CC Address"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-12 col-sm-12 col-xs-12">
                                    <div class="form-horizontal"> 
                                        <div class="form-group">
                                            <label class="col-md-2 col-sm-2 col-xs-12 control-label " width = "10%">Subject<span style="color:#ff9797; font-size:15px; cursor:default;" ></span>
                                            </label>
                                            <div class="col-md-10 col-sm-10 col-xs-12">
                                                <apex:input type="text"  styleClass="form-control" value="{!emailSubject}" id="EmailSubject" html-placeholder="Enter Email Subject"/>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="col-md-2 col-sm-2 col-xs-12 control-label " width = "10%">Body<span style="color:#ff9797; font-size:15px; cursor:default;" ></span>
                                            </label>
                                            <div class="col-md-10 col-sm-10 col-xs-12" >
                                               <apex:inputTextArea id="editor1" value="{!Invoice.Email_Body__c}" label="Email Body" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </div> 
                    
                    
                    <div class="pull-right clr">  
                        <apex:commandbutton id="btnBack" styleClass="cancel"  value="Back" action="{!redirectToInvoice}" immediate="true"  style="margin-right: 10px;"/>
                        <apex:commandbutton styleClass="popup-add save-submit" Value="Attach Timesheet" id="attachTimeSheet"  action="{!attachTimeSheet}"  status="statusSaveTrip" rendered="{!(NOT(hasTimesheetFile) && NOT(isCustomer) && ShowUploadInvoice && PortalRole != 'Partner' && NOT(InvoiceStatus == 'Submitted'))}" />
                        <!-- <apex:commandbutton styleClass="popup-add save-submit" Value="ADD" id="uploadInvoice"  onClick="return ValidateInvoiceDetails();" rerender="divErrorMessageFileType" status="statusSaveTrip"/> -->
                        <apex:commandbutton styleClass="popup-add save-submit" Value="ADD" id="uploadInvoice"  action="{!InsertUpdateInvoice}" onClick="return ValidateInvoiceDetails('Saved');"  status="statusSaveTrip" rendered="{!(NOT(ShowUploadInvoice) &&  Not(isCustomer))}" />
                        <apex:commandbutton styleClass="popup-add save-submit" Value="UPDATE" id="uploadInvoiceUpdate" onClick="return ValidateInvoiceDetails('Saved');" action="{!InsertUpdateInvoice}"  status="statusSaveTrip" rendered="{!(NOT(isCustomer) && ShowUploadInvoice && PortalRole != 'Partner' && NOT(InvoiceStatus == 'Submitted'))}" />
                        
                       
                        
                        <apex:commandbutton id="uploadDisableButton" action="{!InsertUpdateInvoice}" styleClass="hideClass save-submit" />
                        <apex:commandButton id="submitInvoice" styleClass="popup-add save-submit" Value="SUBMIT"  onClick="return ValidateInvoiceDetails('Submitted');" rendered="{!(NOT(isCustomer) && ShowUploadInvoice && PortalRole != 'Partner' && NOT(InvoiceStatus == 'Submitted'))}" status="statusSaveTrip" />
                    </div>
                </div>
            </div>
            <c:ODS_FooterComponent /> 
        </apex:form>
    </body>
</apex:page>