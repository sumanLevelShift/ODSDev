            <script>
            document.getElementById('uploadFile').addEventListener('change', handleFileSelect);
            var fileToUpload;
            var blobfile;
            function handleFileSelect(evt) { 
                var files = evt.target.files;
                fileToUpload = files[0];
            }
            function saveAttachment() { 
                
                if(fileToUpload.size <= 1073741824)
                {
                    var reader = new FileReader();
                    reader.readAsDataURL(fileToUpload);
                    document.getElementById('uploadStatus').style.visibility = 'visible';
                    reader.onload = function(e) 
                    {
                        var fileString = e.target.result;
                        blobfile = fileString;
                        sendAttachmentToController(fileToUpload.name,blobfile);
                    }
                }
                else
                {
                    alert('The maximum allowed file size is 1GB.');
                }
            }
            
            function expandAllProducts(v){
                if(v == true){
                    $('.pbSubsection').css('display','block');
                    $('.showListButton').addClass('hideListButton').removeClass('showListButton');
                }else{
                    $('.pbSubsection').css('display','none');
                    $('.hideListButton').addClass('showListButton').removeClass('hideListButton');
                }
                return false;
            }
            </script>  
            
            
            
