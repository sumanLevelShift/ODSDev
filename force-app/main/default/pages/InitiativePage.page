            <script>
            var utilizationHurs=0.0; 
            var consumedHrs = 0.0;
            var unUtilizedHrs=0.0;
            var remainingHrs=0.0;
            window.onload=function(){
                hrs();
                toHide();
                /*debugger;*/
                var approvalType = getParameterByName('Type');
                if(approvalType == 'Reject'){
                    $('#btnReject').click();
                    
                }
            }
            
            
            function getParameterByName(name, url) {
                if (!url) url = window.location.href;
                name = name.replace(/[\[\]]/g, '\\$&');
                var regex = new RegExp('[?&]' + name + '(=([^&#]*)|&|#|$)'),
                    results = regex.exec(url);
                if (!results) return null;
                if (!results[2]) return '';
                return decodeURIComponent(results[2].replace(/\+/g, ' '));
            }
            </script>   
            
            
            <script>    
            function hrs(){
                var crntInvId =  '{!$CurrentPage.parameters.CurrenInitiativeId}';
                Visualforce.remoting.Manager.invokeAction(
                    '{!$RemoteAction.ODS_InitiativeController.GetUtilizedHours}', 
                    crntInvId,
                    function(result, event){
                        if(result === null)
                        {
                            utilizationHurs = 0.0;
                            consumedHrs = 0.0;
                            unUtilizedHrs=0.0;
                            remainingHrs=0.0;
                        }
                        else
                        {                   
                            var hrsArray = result.split("|");                                     
                            utilizationHurs = hrsArray[0];
                            consumedHrs = hrsArray[1];
                            unUtilizedHrs=hrsArray[2];
                            remainingHrs=hrsArray[3];
                        }
                    });
                
            }
            
            var chart = AmCharts.makeChart("chartdiv", {
                "theme": "light",
                "type": "gauge",
                "axes": [{
                    "topTextFontSize": 20,
                    "topTextYOffset": 70,
                    "axisColor": "#31d6ea",
                    "axisThickness": 1,
                    "endValue": 100,
                    "gridInside": true,
                    "inside": true,
                    "radius": "50%",
                    "valueInterval": 10,
                    "tickColor": "#67b7dc",
                    "startAngle": -90,
                    "endAngle": 90,
                    "unit": "%",
                    "bandOutlineAlpha": 0,
                    "bands": [{
                        "color": "#4ECAF4",
                        "endValue": 100,
                        "innerRadius": "105%",
                        "radius": "130%",
                        "gradientRatio": [0, 0, 0],
                        "startValue": 0
                    }, {
                        "color": "#4ECAF4",
                        "endValue": 0,
                        "innerRadius": "105%",
                        "radius": "130%",
                        "gradientRatio": [0.5, 0, -0.5],
                        "startValue": 0
                    }]
                }],
                "arrows": [{
                    "alpha": 1,
                    "innerRadius": "35%",
                    "nailRadius": 0,
                    "radius": "130%"
                }]
            });
            
            setInterval(randomValue, 50);
            
            // set random value
            function randomValue() {
                var value = utilizationHurs;
                var consumedValue = consumedHrs;
                chart.arrows[0].setValue(value);
                
                chart.axes[0].setTopText(consumedValue + " Hours");
                // adjust darker band to new value
                chart.axes[0].bands[1].setEndValue(value);
            }
            var chartnew = AmCharts.makeChart("chartdivnew", {
                "theme": "light",
                "type": "gauge",
                "axes": [{
                    "topTextFontSize": 20,
                    "topTextYOffset": 70,
                    "axisColor": "#31d6ea",
                    "axisThickness": 1,
                    "endValue": 100,
                    "gridInside": true,
                    "inside": true,
                    "radius": "50%",
                    "valueInterval": 10,
                    "tickColor": "#67b7dc",
                    "startAngle": -90,
                    "endAngle": 90,
                    "unit": "%",
                    "bandOutlineAlpha": 0,
                    "bands": [{
                        "color": "#4ECAF4",
                        "endValue": 100,
                        "innerRadius": "105%",
                        "radius": "130%",
                        "gradientRatio": [0, 0, 0],
                        "startValue": 0
                    }, {
                        "color": "#4ECAF4",
                        "endValue": 0,
                        "innerRadius": "105%",
                        "radius": "130%",
                        "gradientRatio": [0.5, 0, -0.5],
                        "startValue": 0
                    }]
                }],
                "arrows": [{
                    "alpha": 1,
                    "innerRadius": "35%",
                    "nailRadius": 0,
                    "radius": "130%"
                }]
            });
            
            setInterval(randomValueNew, 50);
            
            // set random value
            function randomValueNew() {
                var value = unUtilizedHrs;
                var remainingValue = remainingHrs;
                chartnew.arrows[0].setValue(value);
                
                chartnew.axes[0].setTopText(remainingValue + " Hours");
                // adjust darker band to new value
                chartnew.axes[0].bands[1].setEndValue(value);
            }
            function toHide(){
                var status =  '{!$CurrentPage.parameters.Status}'; 
                if(status == '' ||status == 'Re-evaluate' || status == 'New' || status == 'Initiative Submitted' || status == 'Saved'  ){
                    $('#chartdiv').hide();
                    $('#chartdivnew').hide();
                    $('#chartdiv2').hide(); 
                    
                }
            }
            </script>
            
            
