            <apex:actionFunction name="passJSONToController" action="{!SaveTimesheet}" status="statusSaveTrip" rerender="jsPanel,hdnActionPanel,showPageMsg" immediate="false" oncomplete="javascript: if({!SaveTimesheetError==false}){PostSaveTimesheet();}">
                <apex:param name="PassedTimesheetJSON" assignTo="{!PassedTimesheetJSON}" value="" id="TimesheetJSONId" />
                <apex:param name="hdnActionValue" assignTo="{!hdnActionValue}" value="" id="hdnActionValueId"/>
            </apex:actionFunction>
            <apex:actionFunction name="passWeekDateToController" action="{!GetWeeklyTimesheet}" status="statusSaveTrip" rerender="jsPanel,showPageMsg" oncomplete="javascript: if({!GetWeeklyTimesheetError==false}){BindJSONDataToPage();}">
                <apex:param name="PassedWeekFromDate" assignTo="{!PassedWeekFromDate}" value="" id="PassedWeekFromDateId" />
                <apex:param name="PassedWeekToDate" assignTo="{!PassedWeekToDate}" value="" id="PassedWeekToDateId" />
            </apex:actionFunction>
            
            <apex:actionFunction name="ApplySearchAction" action="{!GetTimesheetByAccountServiceID}" status="statusSaveTrip" rerender="listPanel,jsPanel,SearchResultsPanel,CustomerPanel,showPageMsg" oncomplete="javascript: if({!GetTimesheetByAccountServiceIDError==false}){BindJSONDataToPage();}" immediate="true">
                <apex:param name="SelectedAccountId" value="" assignTo="{!AccountId}" />
                <apex:param name="SelectedServiceID" value="" assignTo="{!ServiceID}" />
            </apex:actionFunction>
            
              <apex:actionFunction name="selectedInitiativeRecord" immediate="false" status="statusSaveTrip" action="{!selectedInitiativeRecord}" rerender="SearchResultsPanel, myModal" oncomplete="TpmTimesheet('{!TechnicalProjectManagerName}');" >
                <apex:param name="InitId" value="" assignTo="{!InitId}" />
            </apex:actionFunction>     
             <apex:actionFunction name="getInitiativeBillingTypeAction" immediate="false" status="statusSaveTrip" action="{!selectedInitiativeRecord}" rerender="SearchResultsPanel, myModal" oncomplete="selectIBTTimesheet('{!SelectedInitiativeBillingType}');" >
                <apex:param name="InitId" value="" assignTo="{!InitId}" />
            </apex:actionFunction> 
            <apex:actionFunction name="ApproveRejectAction" action="{!GetTimeSheetIdFromAction}" rerender="SearchResultsPanel, myModal" immediate="true">
                <apex:param name="CurrentTimesheetId" value="" assignTo="{!CurrenTimesheetId}" />
            </apex:actionFunction>
            
            <apex:actionFunction name="RejectAction" action="{!RejectTimesheet}" reRender="SearchResultsPanel,showPageMsg" status="statusSaveTrip" oncomplete="javascript: if({!RejectTimesheetError==false}){reloadpage();}else{reloadpageOnPopupClose();}">
                <apex:param name="timeshtCmnts" value="" assignTo="{!TimesheetComments}" />
            </apex:actionFunction>
            <apex:actionFunction name="ApproveAction" action="{!ApproveTimesheet}" reRender="SearchResultsPanel,showPageMsg" status="statusSaveTrip" oncomplete="javascript: if({!ApproveTimesheetError==false}){reloadpage();}else{reloadpageOnPopupClose();}" />
