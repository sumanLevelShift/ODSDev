        //function to restrict numbers in datepicker
        function isNumber(evt) {
            evt = (evt) ? evt : window.event;
            var charCode = (evt.which) ? evt.which : evt.keyCode;
            if (!(charCode > 31 && (charCode < 48 || charCode > 57) && charCode ==91 )) {
                return false;
            }
            return true;
        }
        
        
        function sortTable(n) {
            debugger;
            var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
            table = document.getElementById("myTable2");
            switching = true;
            //Set the sorting direction to ascending:
            dir = "asc"; 
            /*Make a loop that will continue until
                no switching has been done:*/
            while (switching) {
                //start by saying: no switching is done:
                switching = false;
                rows = table.getElementsByTagName("TR");
                /*Loop through all table rows (except the
                    first, which contains table headers):*/
                for (i = 1; i < (rows.length - 1); i++) {
                    //start by saying there should be no switching:
                    shouldSwitch = false;
                    /*Get the two elements you want to compare,
                      one from current row and one from the next:*/
                        x = rows[i].getElementsByTagName("TD")[n];
                        y = rows[i + 1].getElementsByTagName("TD")[n];
                        /*check if the two rows should switch place,
                      based on the direction, asc or desc:*/
                        if (dir == "asc") {
                            if (x.innerHTML.toLowerCase() > y.innerHTML.toLowerCase()) {
                                //if so, mark as a switch and break the loop:
                                shouldSwitch = true;
                                break;
                            }
                        } else if (dir == "desc") {
                            if (x.innerHTML.toLowerCase() < y.innerHTML.toLowerCase()) {
                                //if so, mark as a switch and break the loop:
                                shouldSwitch = true;
                                break;
                            }
                        }
                    }
                if (shouldSwitch) {
                    /*If a switch has been marked, make the switch
                      and mark that a switch has been done:*/
                        rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
                        switching = true;
                        //Each time a switch is done, increase this count by 1:
                        switchcount ++; 
                    } else {
                        /*If no switching has been done AND the direction is "asc",
                      set the direction to "desc" and run the while loop again.*/
                        if (switchcount == 0 && dir == "asc") {
                            dir = "desc";
                            switching = true;
                        }
                    }
            }
        }
        /* pass value to module popup */
        function checkJS(id, datefrom, Workperformedtoday,Worktobeperformed,Issuesandconcern,datetest)
        {
            //alert(datetest);
            var SRDate= '';
            var SRWorkperformedtoday= '';
            var SRWorktobeperformed= '';
            var SRIssuesandconcern= '';
           var StatusReport = '';
            var today = new Date(datefrom);
            var dd = today.getDate();
            var mm = today.getMonth()+1; 
            var yyyy = today.getFullYear();

            today = mm+'-'+dd+'-'+yyyy;
           
            var SRWorkperformedtoday= Workperformedtoday;
            var SRWorktobeperformed= Worktobeperformed;
            var SRIssuesandconcern= Issuesandconcern;
             var StatusReport = datetest;
             if(datetest =="Weekly"){
                $("#dailyid").css("display","none");
                $("#nextdailyid").css("display","none");
            }else{            
                $("#weeklyid").css("display","none");
                $("#nextweekid").css("display","none");
            }
            jQuery('[id$=SRStatusDate]').html(today)
            jQuery('[id$=eventId1]').html(SRWorkperformedtoday)
            jQuery('[id$=eventId12]').html(SRWorkperformedtoday)
            jQuery('[id$=SRWorktobePerformedtomorrow]').html(SRWorktobeperformed)
            jQuery('[id$=SRWorktobePerformedtomorrows]').html(SRWorktobeperformed)
            jQuery('[id$=SRIssuesandconcern]').html(SRIssuesandconcern)
            $('#SRStatusDate').val(SRDate).format('MMDDYYYY');
            $('#eventId').val(Workperformedtoday);
            $('#SRWorktobePerformedtomorrow').val(Worktobeperformed);
             $('#SRWorktobePerformedtomorrows').val(Worktobeperformed);
            $('#SRIssuesandconcern').val(Issuesandconcern);
            
            
        }
        </script>
        
        
