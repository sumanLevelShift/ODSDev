                        <div class="panel panel-default" >
                            <div class="panel-heading" style="color: #FFFFFF;background-color: #4ECAF4; ">
                                <h3 style=" display:inline; " class="panel-title">Incidents</h3>  
                                <span class="pull-right clickable" style=" margin-top: 0.2px;" ><i class="fa fa-chevron-up" aria-hidden="true"></i></span> 
                            </div> 
                            <div class="panel-body">
                                <apex:pageBlock >
                                    <apex:pageBlockTable StyleClass="datatable timeline" id="pgTable" Style="cellpadding:0; cellspacing:0; width:100%;color:#4ECAF4;"  value="{!incidentEmails}" var="Email"
                                                         rendered="{!(incidentEmails.size!=0 && incidentEmails !='' && incidentEmails !=null ) }">                        
                                        
                                        <apex:column headerValue="Subject"  style="text-align:left; ">
                                            <apex:commandLink value="{!Email.Subject}" action="{!showpopup}" style="white-space: nowrap;" immediate="true" reRender="tstpopup">
                                                <apex:param name="emailId" value="{!Email.id}"/>
                                            </apex:commandLink>
                                        </apex:column>
                                        <apex:column headerValue="Created Date" value="{!Email.CreatedDate}" style="text-align:right !important; width:155px "/>
                                    </apex:pageBlockTable>
                                </apex:pageBlock>
                                <apex:outputPanel id="tstpopup" >
                                    <apex:outputPanel styleClass="BackGPopup" onclick="closePopupBox();" layout="block" rendered="{!displayPopUp}"></apex:outputPanel>
                                    <apex:outputPanel styleClass="custPopup" layout="block" rendered="{!displayPopUp}">
                                        <!-- <apex:commandButton value="X" title="Close the Popup" action="{!closePopup}" immediate="true" reRender="listPanel" styleClass="closeButton" /> -->
                                        <apex:commandLink action="{!closePopup}" title="Close" styleClass="closeButton" immediate="true" reRender="listPanel" >
                                            <svg aria-hidden="true" style="margin-top: 10px;margin-right: 10px;" class="closeIcon">
                                                <use xmlns:xlink="http://www.w3.org/1999/xlink"
                                                     xlink:href="/apexpages/slds/latest/assets/icons/utility-sprite/svg/symbols.svg#close">
                                                </use>
                                            </svg>
                                        </apex:commandLink>
                                        <div id="popupText">
                                            <apex:outputText style=" font-weight: bold !important;" value="{!currentEmail.Subject}" escape="false" />
                                            <br/><br/>
                                            <apex:outputText id="htmlBody" value="{!currentEmail.HTMLBody}" escape="false" />
                                            
                                        </div>
                                        <br/>
                                    </apex:outputPanel>
                                </apex:outputPanel>
                                
                            </div>
                        </div>
                        <div Class = "pull-right">
                            <br/>
                            <input type="button" id="btnCancel" class="cancel" value="Cancel" onclick="return Cancel();"/>
                            &nbsp;
                            <input type="button" id="btnSave" class="save-submit" value="Save" onclick="return Save();" />    
                        </div>
                        <script>
                            var checkBoxValue ='{!HasCommunities}';
                            if(checkBoxValue == 'true')
                            {
                                $('#Has_Communities')[0].checked = true;
                            }
                            else
                            {
                                $('#Has_Communities')[0].checked = false;
                            }
                        var futureTimesheet='{!AllowFutureTimesheets}';
                        if(futureTimesheet == 'true')
                        {
                            $('#Future_Timesheet')[0].checked = true;
                        }
                        else
                        {
                            $('#Future_Timesheet')[0].checked = false;
                        }
                        </script>
                    </apex:outputPanel>
                </div>
            </div>
            <c:ODS_FooterComponent />
        </apex:form>
        
    </body>
</apex:page>