            var Marketing_Cloud_Instance_Name = $("#Marketing_Cloud_Instance_Name").val();
            var Has_Communities = $("#Has_Communities").prop('checked');
            var Future_Timesheet = $("#Future_Timesheet").prop('checked');
            var Salesforce_Products = $("#Salesforce_Products").val();
            var Business_Overview = $("#Business_Overview").val();
            var Customers = $("#Customers").val();
            var Key_Competitors = $("#Key_Competitors").val();
            var Collaborators_Partners = $("#Collaborators_Partners").val();
            var Compliance_Requirements = $("#Compliance_Requirements").val();
            var Current_Painpoints = $("#Current_Painpoints").val();
            var Product_Backlog = $("#Product_Backlog").val();
            var Products_Services_Offered = $("#Products_Services_Offered").val();
            var Salesforce_Roadmap = $("#Salesforce_Roadmap").val();
            var Appexchange_Apps = $("#Appexchange_Apps").val();
            var Customer_Service = $("#Customer_Service").val();
            var CPQ_Product = $("#CPQ_Product").val();
            var Marketing = $("#Marketing").val();
            var Middleware = $("#Middleware").val();
            var ERP = $("#ERP").val();
            var Document_Generation = $("#Document_Generation").val();
            var External_Storage = $("#External_Storage").val();
            var Digital_Signature = $("#Digital_Signature").val();
            var Analytics = $("#Analytics").val();
            var Backup = $("#Backup").val();
            var Project_Management = $("#Project_Management").val();
            var Development_Tools = $("#Development_Tools").val();
            
            //DatatoSave.AccountID = AccountID;
            DatatoSave.Org_Id = Org_Id;
            DatatoSave.Salesforce_AE_Name = Salesforce_AE_Name;
            DatatoSave.Customer_Portal_Access = Customer_Portal_Access;
            DatatoSave.Customer_Engagement_Score = Customer_Engagement_Score;
            DatatoSave.Status_Report_Frequency = Status_Report_Frequency;
            if (Customer_Portal_Access_Status_Date != "")
            {
                DatatoSave.Customer_Portal_Access_Status_Date = Customer_Portal_Access_Status_Date;
            }
            DatatoSave.Weekly_Monthly_Meeting = Weekly_Monthly_Meeting;
            if (Setup_Weekly_Monthly_Meeting_Date != "")
            {
                DatatoSave.Setup_Weekly_Monthly_Meeting_Date = Setup_Weekly_Monthly_Meeting_Date;
            } 
            DatatoSave.Environment_Access = Environment_Access;
            if (Environment_Access_Status_Date != "")
            {
                DatatoSave.Environment_Access_Status_Date = Environment_Access_Status_Date;
            }
            DatatoSave.Onboarding_Document = Onboarding_Document ;
            if (Onboarding_Document_Status_Date != "")
            {
                DatatoSave.Onboarding_Document_Status_Date = Onboarding_Document_Status_Date;
            }
            DatatoSave.LRC = LRC;
            if (LRC_Status_Date != "")
            {
                DatatoSave.LRC_Status_Date = LRC_Status_Date;
            }
            DatatoSave.Instance_Name = Instance_Name;
            DatatoSave.Marketing_Cloud_Instance_Name = Marketing_Cloud_Instance_Name;
            DatatoSave.Salesforce_Products = Salesforce_Products;
            DatatoSave.Business_Overview = Business_Overview;
            DatatoSave.Customers = Customers;
            DatatoSave.Key_Competitors = Key_Competitors;
            DatatoSave.Collaborators_Partners = Collaborators_Partners;
            DatatoSave.Compliance_Requirements = Compliance_Requirements;
            DatatoSave.Current_Painpoints = Current_Painpoints;
            DatatoSave.Product_Backlog = Product_Backlog;
            DatatoSave.Products_Services_Offered = Products_Services_Offered;
            DatatoSave.Salesforce_Roadmap = Salesforce_Roadmap;
            DatatoSave.Has_Communities = Has_Communities;
            DatatoSave.Future_Timesheet = $("#Future_Timesheet").prop('checked');
            DatatoSave.Appexchange_Apps = Appexchange_Apps;
            DatatoSave.Customer_Service = Customer_Service ;
            DatatoSave.CPQ_Product = CPQ_Product;
            DatatoSave.Marketing = Marketing;
            DatatoSave.Middleware = Middleware;
            DatatoSave.ERP = ERP;
            DatatoSave.Document_Generation = Document_Generation;
            DatatoSave.External_Storage = External_Storage;
            DatatoSave.Digital_Signature = Digital_Signature;
            DatatoSave.Analytics = Analytics;
            DatatoSave.Backup = Backup;
            DatatoSave.Project_Management = Project_Management;
            DatatoSave.Development_Tools = Development_Tools;
            var DatatoSaveJSON = JSON.stringify( DatatoSave);
            
            var AccountToSaveData = $(".ddlstAccount").val();
            PassDataToController(DatatoSaveJSON,AccountToSaveData);
        }
