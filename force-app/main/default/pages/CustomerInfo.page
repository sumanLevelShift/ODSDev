                <apex:param name="SelectedServiceID" value="" assignTo="{!ServiceID}" />
            </apex:actionFunction>
            <apex:actionFunction name="PassDataToController" action="{!SaveCustomerInfo}" status="statusSaveTrip" oncomplete="loadAfterSave('{!updatedAccount}','{!updatedservice}');" >
                <apex:param name="DatatoSaveJSON" assignTo="{!DatatoSaveJSON}" value=""/>
                <apex:param name="AccountToSaveData" assignTo="{!AccountToSaveData}" value="" />
            </apex:actionFunction>
            <apex:actionFunction name="doCancel" action="{!CancelChanges}" status="statusSaveTrip" rerender="listPanel" >
            </apex:actionFunction>
            <apex:actionFunction name="closePopupBox" action="{!closePopup}" reRender="listPanel" immediate="True"/>
            
