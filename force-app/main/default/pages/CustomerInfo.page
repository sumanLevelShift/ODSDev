            var Setup_Weekly_Monthly_Meeting_Date = $(".Setup_Weekly_Monthly_Meeting_Date").val();
            var Environment_Access = $(".Environment_Access").val();
            var Environment_Access_Status_Date = $(".Environment_Access_Status_Date").val();
            var Onboarding_Document = $(".Onboarding_Document").val();
            var Onboarding_Document_Status_Date = $(".Onboarding_Document_Status_Date").val();
            var LRC = $(".LRC").val();
            var LRC_Status_Date = $(".LRC_Status_Date").val();
