<apex:page controller="TipsTimesheetPDFController" renderAs="pdf"  showHeader="false" cache="true" applyHtmlTag="false" applyBodyTag="false" >
    <apex:form >
        <html>
            <head>
                <style>
                    @page{
                    size: A4 landscape;
                    margin: 1cm;
                    }                           
                </style>
                
                
            </head>
            <body style="font-family: 'Open Sans', sans-serif; font-size:14px;">
                <apex:variable var="cnt" value="{!0}" />    
                <apex:repeat value="{!TimesheetDetailsWarpperList}" var="t" id="theRepeat">
                    <div class="mid-bg" style="{!if(cnt < 1, 'page-break-before:avoid;','page-break-before:always;')}">
                        <apex:variable var="cnt" value="{!cnt+1}"/>

                        <div class="sub-warp">
                            
                            <div class="mid-white">
                                <div class="logo">
                                    <a href=""><img src="{!URLFOR($Resource.ODS_Assets,'images/logo.png')}" alt="logo"  /></a>
                                </div>
                                
                                <h1 style="float:left; font-size:18px;"> Timesheet - {!t.TimesheetAccount} - {!t.TimesheetAccountService}</h1>
                                
                                <div class="mid-dateroll" style="float:right; margin-bottom:25px;">
                                    <div style=" margin-top:5px;"><strong  style="text-align: right; width:100px; float: left;">Status:&nbsp;</strong><label style="font-weight:normal;" id="lblStatus">{!t.CurrentTimesheetStatus}</label> </div>  
                                    
                                    <div style=" margin-top:5px;"><strong style="text-align: right; width:100px; float: left;">From :&nbsp;</strong><label style="font-weight:normal;" id="lblStatus">{!t.FromDate}</label> </div>
                                    <div   style=" margin-top:5px;"><strong  style="text-align: right; width:100px; float: left;">To :&nbsp;</strong><label style="font-weight:normal;" id="lblStatus">{!t.ToDate}</label> </div>
                                </div> 
                                
                                <div style="clear:both"></div>  
                                <apex:outputText value="{!t.inputString}" escape="false"></apex:outputText>
                                
                                <div class="mid-dateroll" style=" margin-top: 15px;">
                                    <div style="float:left;">
                                        <div id="divStatus"  style=" margin-top:15px;"><strong>Approver Name:&nbsp;</strong><label style="font-weight:normal;" id="lblStatus">{!t.ManagerName}</label> </div>
                                        <div id="divStatus"  style=" margin-top:5px;"><strong>Comments:&nbsp;</strong><label style="font-weight:normal;" id="lblStatus">{!t.Comments}</label> </div>
                                    </div>
                                    <div style="float:right;">
                                        <div id="divStatus" style=" margin-top:15px;" ><strong>Signature:&nbsp;</strong><label style="font-weight:normal;" id="lblStatus">{!t.ApproverName}</label> </div>
                                        <div id="divStatus" style=" margin-top:5px;" ><strong>Approved Date:&nbsp;</strong><label style="font-weight:normal;" id="lblStatus">{!t.CuDt}</label> </div>  
                                    </div>
                                    <div class="clr"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </apex:repeat>
            </body> 
        </html>
    </apex:form>
</apex:page>